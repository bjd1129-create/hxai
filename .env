# .env - 大唐智能环境变量

# ===========================================
# 大唐智能 · 最强模型配置
# 策略：只考虑性能，不考虑成本
# 更新时间：2026-03-23 23:07
# ===========================================

# ===========================================
# 默认最强模型（综合最强）
# ===========================================
DEFAULT_MODEL=qwen3.5-plus
DEFAULT_MODEL_SOURCE=dashscope

# ===========================================
# 按任务类型的最强模型
# ===========================================
# 代码生成最强
CODE_MODEL=qwen3-coder-plus
# 深度思考/推理最强
REASONING_MODEL=glm-5
# 长上下文最强
LONG_CONTEXT_MODEL=kimi-k2.5
# 视觉理解最强
VISION_MODEL=qwen3.5-plus
# 战略决策最强
STRATEGY_MODEL=qwen3.5-plus

# ===========================================
# MiniMax API 配置（备用）
# ===========================================
MINIMAX_API_KEY=sk-cp-dfOHnWCqr1Iv_l-Tykxkt7Ok4NCAAdQsx2jCEA2TQEQElC9y7Fj1FwTx_a5EfiHlu0I0CzYGtz8SN5gDrKdBzQgexNbinTS3XGWHzI1AB9qxZ58zRLdThC0
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5

# ===========================================
# 百炼大模型配置（主用 - 最强模型源）
# ===========================================
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_API_KEY=sk-sp-b879148afe854c45b2850757aa4997fd
DASHSCOPE_MODEL=qwen3.5-plus
DASHSCOPE_ANTHROPIC_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# 可用模型列表（按性能排序）
DASHSCOPE_MODELS=qwen3.5-plus,qwen3-coder-plus,glm-5,kimi-k2.5,qwen3-max-2026-01-23,qwen3-coder-next,glm-4.7,minimax-m2.5

# ===========================================
# OpenAI 兼容配置（用于 LangChain/CrewAI）
# ===========================================
# 默认使用百炼最强模型
OPENAI_API_BASE=https://coding.dashscope.aliyuncs.com/v1
OPENAI_API_KEY=sk-sp-b879148afe854c45b2850757aa4997fd

# 团队配置
TEAM_SIZE=3
TEAM_MEMBERS=李小民，房玄龄，李靖
